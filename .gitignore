# Generated by Cargo
# Will contain the executable when built
/target/

# Generated by rustfmt
# Backup files of the rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
# .pdb files are for the Microsoft Visual Studio debugger
*.pdb

# Cargo mutants, a mutation testing tool, generates this directory
**/mutants.out/

# RustRover (JetBrains IDE)
.idea/

*.redb
vector.hnsw
benchmarks/.env.benchmarks.local
benchmarks/LongMemEval/data/longmemeval_s_cleaned.json
benchmarks/results/LongMemEval/
benchmarks/ranking_tuner/*
*.*_hnsw
*.db
/tenants/*
/.fastembed_cache/*
*.db-wal
*.db-shm

# Terraform
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.lock.info
.terraform.tfstate.lock.info